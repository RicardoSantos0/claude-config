# Claude local/machine-specific settings
.claude/settings.local.json

# Secrets & credentials
.env
*.key
*.pem
secrets/

# OS noise
.DS_Store
Thumbs.db
desktop.ini

# Python
__pycache__/
*.pyc
*.pyo
.venv/
.pytest_cache/
*.egg-info/
dist/
.coverage

# MAS runtime data (project-specific, not committed)
mas/projects/
audit.log
mas/working_state/

# MAS data and logs (not committed)
mas/data/
mas/logs/
# Ignore all YAML, DB, and log files in mas/data and mas/logs
mas/data/*
mas/logs/*
# Ignore all YAML, DB, and log files at the root of mas/
mas/*.db
mas/*.yaml
mas/*.log

# MAS roster (committed, but large binaries excluded)
mas/roster/**/*.bak

# Skills runtime/auth data
skills/notebooklm/data/browser_state/
skills/notebooklm/data/auth_info.json
